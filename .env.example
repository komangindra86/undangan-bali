APP_NAME="Undangan Pernikahan Bali"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Makassar

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=undangan_bali
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Midtrans QRIS Wedding Gift (gunakan key Sandbox saat pengembangan)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Payment provider Wedding Gift: midtrans atau xendit
WEDDING_GIFT_PAYMENT_PROVIDER=midtrans

# Xendit Payment Link / Invoice Wedding Gift (gunakan key development saat pengembangan)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Google Login Mobile. Isi dengan Web Client ID dan Android Client ID, pisahkan koma jika lebih dari satu.
GOOGLE_CLIENT_IDS=

# Fee ditentukan aplikasi, bukan oleh pasangan.
WEDDING_GIFT_FEE_TYPE=flat
WEDDING_GIFT_FEE_VALUE=2000
WEDDING_GIFT_FEE_FLAT_BELOW_AMOUNT=100000
WEDDING_GIFT_FEE_FLAT_VALUE=2000
WEDDING_GIFT_FEE_PERCENT_VALUE=2
WEDDING_GIFT_MINIMUM_AMOUNT=10000
WEDDING_GIFT_PAYOUT_MINIMUM_AMOUNT=50000
